# Example environment file for docker-compose
# Copy to .env and customize for local development: cp example.env .env

# Postgres
POSTGRES_USER=agenda
POSTGRES_PASSWORD=agenda
POSTGRES_DB=agenda
DB_HOST=db
DB_PORT=5432

# Host ports (mapping host:container)
QUARKUS_HOST_PORT=8080
ADMINER_PORT=8081
KEYCLOAK_PORT=8082

# Keycloak admin (used only for local dev)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

